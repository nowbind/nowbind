# ---------------------------------------------------------------------------
# NowBind frontend configuration
# Copy to frontend/.env.local for local development.
#
# NEXT_PUBLIC_API_URL: Browser-facing API URL
# NEXT_PUBLIC_SITE_URL: Canonical frontend URL
# NEXT_API_BASE_URL: Optional server-side override for rewrites/proxy
#   - Usually not needed in local dev.
#   - Use when server-side API base differs from NEXT_PUBLIC_API_URL.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_API_BASE_URL=http://localhost:8080
GEMINI_API_KEY=your_gemini_api_key_here