# ---------------------------------------------------------------------------
# NowBind backend configuration
# Copy to backend/.env for local development.
#
# Local (host machine):
# DATABASE_URL=postgres://nowbind:nowbind_dev@localhost:5432/nowbind?sslmode=disable
#
# Docker Compose:
# DATABASE_URL=postgres://nowbind:nowbind_dev@host.docker.internal:5432/nowbind?sslmode=disable
# ---------------------------------------------------------------------------

PORT=8080
DATABASE_URL=postgres://nowbind:nowbind_dev@localhost:5432/nowbind?sslmode=disable
DB_MODE=local
# Required: at least 32 characters. Example:
# JWT_SECRET=5f8f22a8cb5ffccf3f6f69b59f6bca8d7f1bd5c84709f2de9d3f6c7a9d31b0ea
JWT_SECRET=
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# Optional: share auth cookies across subdomains (for example ".example.com")
# COOKIE_DOMAIN=

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Magic-link email via Gmail OAuth2 (optional)
# EMAIL_SENDER=
# GMAIL_CLIENT_ID=        # falls back to GOOGLE_CLIENT_ID when empty
# GMAIL_CLIENT_SECRET=    # falls back to GOOGLE_CLIENT_SECRET when empty
# GMAIL_REFRESH_TOKEN=

# Web Push / VAPID (optional)
# Generate keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Cloudflare R2 media storage (optional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# Content Moderation Service (optional)
# The Go backend calls this FastAPI service for NSFW/spam detection.
# MODERATION_SERVICE_URL=http://localhost:8090
# MODERATION_INTERNAL_SECRET=generate-a-random-32-char-string-here
