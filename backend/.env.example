PORT=8080
DATABASE_URL=postgres://nowbind:nowbind_dev@localhost:5432/nowbind?sslmode=disable
DB_MODE=local
JWT_SECRET=dev-secret-change-me-in-production
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# Cookie domain for cross-subdomain sharing (optional, e.g. ".example.com")
# COOKIE_DOMAIN=

# Google OAuth (optional - enables Google login)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional - enables GitHub login)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Email sending via Gmail OAuth2 (optional - enables magic link login)
# EMAIL_SENDER=
# GMAIL_CLIENT_ID=        # defaults to GOOGLE_CLIENT_ID if not set
# GMAIL_CLIENT_SECRET=    # defaults to GOOGLE_CLIENT_SECRET if not set
# GMAIL_REFRESH_TOKEN=

# Web Push / VAPID (optional - enables push notifications)
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Cloudflare R2 (optional - enables media uploads)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
